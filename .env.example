# Registry Configuration Example
# Copy this file to .env.development or .env.production and adjust as needed

# Registry URL
# Local development: http://localhost:8082
# Production: https://apps.calimero.network
VITE_REGISTRY_URL=http://localhost:8082

# To test production registry locally:
# VITE_REGISTRY_URL=https://apps.calimero.network pnpm dev
